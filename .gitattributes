# Normalize text files in the repository to LF in Git.
* text=auto eol=lf

# Keep Windows project/user-generated binaries untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.pdb binary
*.zip binary

# Source and project files.
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.axaml text eol=lf
*.xaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.props text eol=lf
*.targets text eol=lf
Makefile text eol=lf
